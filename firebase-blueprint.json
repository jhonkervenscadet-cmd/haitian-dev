      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "destinataire": { "type": "string" },
        "email": { "type": "string" },
        "objet": { "type": "string" },
        "message": { "type": "string" },
        "statut": { "type": "string" }
      },
      "required": ["id", "destinataire", "email", "objet", "message", "statut"]
    },
    "formation": {
      "title": "Formation",
      "description": "Premium training courses d'élite",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "titre": { "type": "string" },
        "formateur": { "type": "string" },
        "dateDebut": { "type": "string" },
        "duree": { "type": "string" },
        "niveau": { "type": "string" },
        "organisme": { "type": "string" },
        "lienInscription": { "type": "string" },
        "urlImage": { "type": "string" }
      },
      "required": ["id", "titre", "formateur", "dateDebut", "duree", "niveau", "organisme"]
    },
    "article": {
      "title": "Article",
      "description": "Tech blog articles or learning posts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "readTime": { "type": "string" },
        "author": { "type": "object" },
        "date": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["id", "title", "content"]
    },
    "doc": {
      "title": "Documentation",
      "description": "Technical instruction guides",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "sections": { "type": "array" }
      },
      "required": ["id", "title"]
    },
    "projectAccess": {
      "title": "ProjectAccess",
      "description": "Admin generated CMS password and API tokens given to clients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "projectName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "adminLink": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "apiToken": { "type": "string" },
        "dbUri": { "type": "string" }
      },
      "required": ["id", "clientName", "projectName", "clientEmail", "adminLink", "username", "password"]
    },
    "partnerRequest": {
      "title": "PartnerRequest",
      "description": "Enterprise and business collaboration partnership proposals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "contactName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "companyName", "contactName", "email", "message"]
    }
