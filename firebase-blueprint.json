{
  "entities": {
    "project": {
      "title": "Project",
      "description": "Portofolio projects built by HaitianDev",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "tech": { "type": "array" },
        "demoUrl": { "type": "string" },
        "githubUrl": { "type": "string" }
      },
      "required": ["id", "title"]
    },
    "testimonial": {
      "title": "Testimonial",
      "description": "Reviews and ratings given by clients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "roleCompany": { "type": "string" },
        "quote": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "rating": { "type": "number" }
      },
      "required": ["id", "name", "quote"]
    },
    "landingStat": {
      "title": "LandingStat",
      "description": "Key statistics displayed on the landing page under the hero section",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fondateur": { "type": "string" },
        "expert": { "type": "string" },
        "projet": { "type": "string" },
        "anne": { "type": "string" }
      },
      "required": ["id", "fondateur", "expert", "projet", "anne"]
    },
    "appStat": {
      "title": "AppStat",
      "description": "Global application landing statistics with fixed fields",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fondateur": { "type": "string" },
        "expert": { "type": "string" },
        "projet": { "type": "string" },
        "anne": { "type": "string" }
      },
      "required": ["id", "fondateur", "expert", "projet", "anne"]
    },
    "partner": {
      "title": "Partner",
      "description": "Partner organizations or clients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "quoteRequest": {
      "title": "QuoteRequest",
      "description": "Submissions from clients requesting a quote (Devis)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "description": { "type": "string" },
        "budget": { "type": "string" },
        "deadline": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "type", "name", "email", "description"]
    },
    "quote": {
      "title": "Quote",
      "description": "Detailed project quote requests",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "email": { "type": "string" },
        "company": { "type": "string" },
        "specs": { "type": "string" },
        "estimatedBudget": { "type": "string" },
        "desiredDeadline": { "type": "string" },
