  "firestore": {
    "acces_projets": {
      "schema": "projectAccess",
      "description": "Secure access keys and CMS endpoints of client projects"
    },
    "projects": {
      "schema": "project",
      "description": "Static & dynamic portfolio projects list"
    },
    "testimonials": {
