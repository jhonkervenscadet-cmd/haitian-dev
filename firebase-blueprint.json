        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "clientName", "email", "serviceType", "status"]
    },
    "user": {
      "title": "User",
      "description": "User profiles and permissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
